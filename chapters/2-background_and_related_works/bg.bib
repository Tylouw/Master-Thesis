}

@inproceedings{markertRoboticPeginHoleInsertion2023,
  title = {Robotic {{Peg-in-Hole Insertion}} with {{Tight Clearances}}: {{A Force-based Deep Q-Learning Approach}}},
  shorttitle = {Robotic {{Peg-in-Hole Insertion}} with {{Tight Clearances}}},
  booktitle = {2023 {{International Conference}} on {{Machine Learning}} and {{Applications}} ({{ICMLA}})},
  author = {Markert, Timo and Hoerner, Elias and Matich, Sebastian and Theissler, Andreas and Atzmueller, Martin},
