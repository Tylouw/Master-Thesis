}

@inproceedings{tangAutonomousAlignmentPeg2016,
  title = {Autonomous Alignment of Peg and Hole by Force/Torque Measurement for Robotic Assembly},
  booktitle = {2016 {{IEEE International Conference}} on {{Automation Science}} and {{Engineering}} ({{CASE}})},
  author = {Tang, Te and Lin, Hsien-Chung and Zhao, Yu and Chen, Wenjie and Tomizuka, Masayoshi},
  date = {2016-08},
  pages = {162--167},
  issn = {2161-8089},
  doi = {10.1109/COASE.2016.7743375},
  url = {https://ieeexplore.ieee.org/document/7743375},
  urldate = {2026-04-28},
  abstract = {In the past years, many methods have been developed for robotic peg-hole-insertion to automate the assembly process. However, many of them are based on the assumption that the peg and hole are well aligned before insertion starts. In practice, if there is a large pose(position/orientation) misalignment, the peg and hole may suffer from a three-point contact condition where the traditional assembly methods cannot work. To deal with this problem, this paper proposes an autonomous alignment method by force/torque measurement before insertion phase. A three-point contact model is built up and the pose misalignment between the peg and hole is estimated by force and geometric analysis. With the estimated values, the robot can autonomously correct the misalignment before applying traditional assembly methods to perform insertions. A series of experiments on a FANUC industrial robot and a H7h7 tolerance peg-hole testbed validate the effectiveness of the proposed method. Experimental results show that the robot is able to perform peg-hole-insertion from three-point contact conditions with 96\% success rate.},
  eventtitle = {2016 {{IEEE International Conference}} on {{Automation Science}} and {{Engineering}} ({{CASE}})},
  keywords = {Force,Force measurement,Friction,Iron,Sensors,Service robots},
  file = {/home/tilo/snap/zotero-snap/common/Zotero/storage/INSHN3F7/Tang et al. - 2016 - Autonomous alignment of peg and hole by forcetorque measurement for robotic assembly.pdf;/home/tilo/snap/zotero-snap/common/Zotero/storage/M87T49JG/7743375.html}
}

@inproceedings{thankarajThatSoundsRight2023,
  title = {That {{Sounds Right}}: {{Auditory Self-Supervision}} for {{Dynamic Robot Manipulation}}},
  shorttitle = {That {{Sounds Right}}},
  booktitle = {Proceedings of {{The}} 7th {{Conference}} on {{Robot Learning}}},
  author = {Thankaraj, Abitha and Pinto, Lerrel},
  date = {2023-12-02},
  pages = {1036--1049},
  publisher = {PMLR},
  issn = {2640-3498},
  url = {https://proceedings.mlr.press/v229/thankaraj23a.html},
  urldate = {2026-04-28},
  abstract = {Learning to produce contact-rich, dynamic behaviors from raw sensory data has been a longstanding challenge in robotics. Prominent approaches primarily focus on using visual and tactile sensing. However, pure vision often fails to capture high-frequency interaction, while current tactile sensors can be too delicate for large-scale data collection. In this work, we propose a data-centric approach to dynamic manipulation that uses an often ignored source of information – sound. We first collect a dataset of 25k interaction-sound pairs across five dynamic tasks using contact microphones. Then, given this data, we leverage self-supervised learning to accelerate behavior prediction from sound. Our experiments indicate that this self-supervised ‘pretraining’ is crucial to achieving high performance, with a 34.534.534.5\% lower MSE than plain supervised learning and a 54.354.354.3\% lower MSE over visual training. Importantly, we find that when asked to generate desired sound profiles, online rollouts of our models on a UR10 robot can produce dynamic behavior that achieves an average of 11.511.511.5\% improvement over supervised learning on audio similarity metrics. Videos and audio data are best seen on our project website: aurl-anon.github.io},
  eventtitle = {Conference on {{Robot Learning}}},
  langid = {english},
  file = {/home/tilo/snap/zotero-snap/common/Zotero/storage/NQ2RRGAS/Thankaraj and Pinto - 2023 - That Sounds Right Auditory Self-Supervision for Dynamic Robot Manipulation.pdf}
}

@article{untenPeginHoleUsingTransient2023a,
  title = {Peg-in-{{Hole Using Transient Information}} of {{Force Response}}},
  author = {Unten, Hikaru and Sakaino, Sho and Tsuji, Toshiaki},
  date = {2023-06},
  journaltitle = {IEEE/ASME Transactions on Mechatronics},
  volume = {28},
  number = {3},
  pages = {1674--1682},
  issn = {1941-014X},
  doi = {10.1109/TMECH.2022.3224907},
  url = {https://ieeexplore.ieee.org/document/9969171/},
  urldate = {2026-04-29},
  abstract = {In precision assembly, a peg is guided into a hole with a tolerance smaller than the position accuracy. Although force/torque sensing can estimate the relative position between the peg and hole accurately, its performance is impaired because of the degradation of estimation accuracy caused by transient error at the time of the collision. We found in this study that if contact state transitions can be generated reproducibly, accurate relative positions can be derived from the transient responses, which were previously regarded as errors. We propose a method that focuses on this characteristic. The transition in the contact state is determined by force/torque responses. Then, the estimation accuracy of the direction of the hole improves by using only the force/torque responses of a specific contact state. Additionally, the time between the contact and estimation of the relative position is reduced by using the transient force information.},
  keywords = {Estimation,Force,Force control,Force sensors,Mechatronics,motion control,motion planning,robotic assembly,Task analysis,Trajectory,Transient analysis},
  file = {/home/tilo/snap/zotero-snap/common/Zotero/storage/GELLCMRW/Unten et al. - 2023 - Peg-in-Hole Using Transient Information of Force Response.pdf}
}

